# Notion
NOTION_API_KEY=ntn_your_notion_api_key
NOTION_DATABASE_ID=your_notion_database_id
# Optional: use if your workspace has a separate data source id
# NOTION_DATA_SOURCE_ID=your_notion_data_source_id

# Agent behavior
NOTION_SOURCE=telegram
DEFAULT_STATUS=New
DEFAULT_PRIORITY=Medium
RESEARCH_CONFIDENCE_THRESHOLD=0.8

# Tavily web research
TAVILY_API_KEY=tvly-your-tavily-key

# Optional LLM paragraph summarization for research
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
